// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum HabitType {
  DAILY
  WEEKLY
  MONTHLY
}

enum HabitStatus {
  DONE
  SKIP
  FAIL
}

enum RepeatPattern {
  EVERYDAY
  ALTERNATE_DAYS
  CUSTOM
}

enum LifeArea {
  HEALTH
  CAREER
  MIND
}

model User {
  id                String      @id @default(cuid())
  email             String      @unique
  emailVerified     DateTime?
  passwordHash      String?
  name              String?
  image             String?
  timezone          String      @default("UTC")
  level             Int         @default(1)
  xp                Int         @default(0)
  streakFreezeCount Int         @default(1)
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  habits            Habit[]
  logs              HabitLog[]
  streaks           Streak[]
  moodLogs          MoodLog[]
  activities        Activity[]
  accounts          Account[]
  sessions          Session[]
}

model Habit {
  id               String        @id @default(cuid())
  userId           String
  title            String
  description      String?
  type             HabitType
  repeatPattern    RepeatPattern
  customWeekdays   Int[]         @default([])
  reminderTime     String?
  lifeArea         LifeArea
  isArchived       Boolean       @default(false)
  stackAfterHabitId String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  user             User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  logs             HabitLog[]
  streak           Streak?
}

model HabitLog {
  id          String      @id @default(cuid())
  userId      String
  habitId     String
  date        DateTime
  status      HabitStatus
  note        String?
  completedAt DateTime?
  createdAt   DateTime    @default(now())

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  habit       Habit       @relation(fields: [habitId], references: [id], onDelete: Cascade)

  @@unique([habitId, date])
}

model Streak {
  id           String      @id @default(cuid())
  userId       String
  habitId      String      @unique
  currentCount Int         @default(0)
  longestCount Int         @default(0)
  freezeUsedAt DateTime?
  updatedAt    DateTime    @updatedAt

  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  habit        Habit       @relation(fields: [habitId], references: [id], onDelete: Cascade)
}

model MoodLog {
  id        String      @id @default(cuid())
  userId    String
  moodScore Int
  note      String?
  loggedAt  DateTime    @default(now())

  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Activity {
  id        String      @id @default(cuid())
  userId    String
  message   String
  metadata  Json?
  createdAt DateTime    @default(now())

  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
